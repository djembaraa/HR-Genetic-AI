generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Job {
  id          Int         @id @default(autoincrement())
  title       String
  department  String
  description String
  createdAt   DateTime    @default(now())
  candidates  Candidate[]
}

model Candidate {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  cvUrl         String
  appliedJobId  Int?
  appliedJob    Job?     @relation(fields: [appliedJobId], references: [id])
  createdAt     DateTime @default(now())
}
